{
  "name": "@kaleido/sdk",
  "version": "0.1.0",
  "description": "Canvas Effect SDK — defineEffect 生命周期、共享类型与资源解析（ADE / CLI / 运行时共用）",
  "type": "module",
  "license": "MIT",
  "files": [
    "src",
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "main": "./src/index.ts",
  "module": "./src/index.ts",
  "types": "./src/index.ts",
  "publishConfig": {
    "access": "public",
    "main": "./dist/index.js",
    "module": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "prepublishOnly": "tsup"
  },
  "peerDependencies": {
    "gsap": "3.15.0",
    "three": "0.185.1"
  },
  "devDependencies": {
    "tsup": "^8.5.1"
  }
}
